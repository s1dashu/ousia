# Public runtime DSN. Leave empty to build Sentry out of the app.
OUSIA_SENTRY_DSN=
OUSIA_SENTRY_ENVIRONMENT=production
OUSIA_SENTRY_ENABLE_IN_DEVELOPMENT=0

# Native minidumps can contain process memory and require an explicit privacy
# decision. JavaScript error reporting works while this remains disabled.
OUSIA_SENTRY_ENABLE_NATIVE_CRASH_REPORTS=0

# Build-only source-map upload configuration. SENTRY_AUTH_TOKEN is secret and
# must come from CI or an ignored local environment file.
SENTRY_ORG=
OUSIA_SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
