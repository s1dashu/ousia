{
  "name": "pi-gui",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "description": "A lightweight Tauri desktop client for a user-installed Pi agent.",
  "license": "MIT",
  "homepage": "https://github.com/s1dashu/ousia#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s1dashu/ousia.git"
  },
  "bugs": {
    "url": "https://github.com/s1dashu/ousia/issues"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "release:mac": "scripts/release-macos.sh",
    "typecheck": "tsc -b --force",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint && cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hugeicons/core-free-icons": "^4.2.1",
    "@hugeicons/react": "^1.1.7",
    "@pierre/diffs": "^1.2.12",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^7.3.5",
    "vitest": "^4.1.10"
  }
}
