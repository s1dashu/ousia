{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "out/electron",
    "rootDir": "src/electron",
    "types": ["node", "electron"],
    "sourceMap": true
  },
  "include": ["src/electron/**/*.ts", "src/electron/**/*.cts"]
}
